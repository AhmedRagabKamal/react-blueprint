# Enforce strict peer dependency resolution to prevent version collisions
strict-peer-dependencies=true

# Prevent automatic installation of peers, forcing devs to be explicit
auto-install-peers=false

# Lock the Node/pnpm version so the entire team (and CI) uses the exact same engine
engine-strict=true

# Share the workspace lockfile so the entire team (and CI) uses the exact same dependencies
shared-workspace-lockfile=true

# Hoist only exactly what is needed for tooling to function (e.g., eslint)
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*